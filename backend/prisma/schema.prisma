generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum NotificationType {
  BUDGET_WARNING      // pengeluaran > 80% budget
  BUDGET_EXCEEDED     // pengeluaran > 100% budget
  ANALYSIS_DONE       // klaster baru ditemukan
  BADGE_UNLOCKED      // badge baru terbuka
  LEVEL_UP            // naik level
  DAILY_REMINDER      // pengingat catat transaksi
  FORECAST_READY      // prediksi bulan depan siap
  EXPORT_DONE         // ekspor selesai
}

enum ExportFormat {
  PDF
  EXCEL
}

enum ExportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ChallengeType {
  DAILY
  WEEKLY
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relasi
  transactions   Transaction[]
  categories     Category[]
  budgetGoals    BudgetGoal[]
  analysisRuns   AnalysisRun[]
  notifications  Notification[]
  exportLogs     ExportLog[]
  gamification   Gamification?
  reminderConfig ReminderConfig?

  @@map("users")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  description String          // teks mentah → input ke SBERT
  date        DateTime
  categoryId  String?         // null = belum terkategori
  clusterId   String?         // klaster sementara sebelum dikonfirmasi
  embedding   Float[]         // vektor SBERT (dimensi 384)
  isImported  Boolean         @default(false)
  importBatch String?         // referensi ke batch impor CSV
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relasi
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cluster  Cluster?  @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@index([clusterId])
  @@map("transactions")
}

model Category {
  id          String   @id @default(cuid())
  userId      String
  name        String
  icon        String?  // emoji, misal "☕"
  color       String?  // hex color untuk UI
  isSystem    Boolean  @default(false) // kategori bawaan (Pemasukan, dll)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgetGoals  BudgetGoal[]
  forecasts    Forecast[]
  clusters     Cluster[]    // klaster yang di-map ke kategori ini

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model AnalysisRun {
  id               String         @id @default(cuid())
  userId           String
  status           AnalysisStatus @default(PENDING)
  totalTransactions Int           // jumlah transaksi yang dianalisis
  kOptimal         Int?           // jumlah K terbaik (Elbow Method)
  silhouetteScore  Float?         // skor kualitas klaster (−1 s/d +1)
  wcssValues       Json?          // array WCSS per nilai K untuk grafik Elbow
  durationMs       Int?           // durasi proses dalam milidetik
  errorMessage     String?
  createdAt        DateTime       @default(now())
  completedAt      DateTime?

  // Relasi
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clusters Cluster[]

  @@index([userId])
  @@map("analysis_runs")
}

model Cluster {
  id            String   @id @default(cuid())
  analysisRunId String
  clusterIndex  Int      // indeks klaster (0, 1, 2, …)
  centroid      Float[]  // vektor centroid klaster
  size          Int      // jumlah transaksi dalam klaster
  totalAmount   Decimal  @db.Decimal(15, 2)
  isConfirmed   Boolean  @default(false)
  isSkipped     Boolean  @default(false)
  categoryId    String?  // diisi setelah pengguna konfirmasi
  confirmedAt   DateTime?

  // Relasi
  analysisRun  AnalysisRun   @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([analysisRunId])
  @@map("clusters")
}

model BudgetGoal {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  limitAmount Decimal  @db.Decimal(15, 2) // batas maksimal pengeluaran
  month      Int      // 1–12
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relasi
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId, year, month])
  @@map("budget_goals")
}

model Forecast {
  id              String   @id @default(cuid())
  userId          String
  categoryId      String
  targetMonth     Int      // bulan prediksi
  targetYear      Int      // tahun prediksi
  predictedAmount Decimal  @db.Decimal(15, 2)
  windowSize      Int      @default(3) // jumlah bulan data historis untuk SMA
  basedOnMonths   Json     // array {month, year, actual} sebagai input SMA
  createdAt       DateTime @default(now())

  // Relasi
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, targetMonth, targetYear])
  @@index([userId, targetYear, targetMonth])
  @@map("forecasts")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?            // data tambahan: {categoryId, budgetGoalId, badgeId, …}
  createdAt DateTime         @default(now())
  readAt    DateTime?

  // Relasi
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ReminderConfig {
  id              String  @id @default(cuid())
  userId          String  @unique
  isEnabled       Boolean @default(true)
  reminderTime    String  @default("21:00") // format "HH:MM"
  budgetWarningPct Int    @default(80)       // persen threshold peringatan budget

  // Relasi
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminder_configs")
}

model ExportLog {
  id          String       @id @default(cuid())
  userId      String
  format      ExportFormat
  status      ExportStatus @default(PENDING)
  month       Int
  year        Int
  fileUrl     String?      // URL file hasil ekspor
  fileSize    Int?         // ukuran file dalam bytes
  options     Json?        // opsi ekspor: {includePieChart, includeTrend, …}
  errorMessage String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  // Relasi
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("export_logs")
}

model ImportBatch {
  id               String   @id @default(cuid())
  userId           String
  fileName         String
  totalRows        Int
  successCount     Int      @default(0)
  errorCount       Int      @default(0)
  errorDetails     Json?    // array {row, reason}
  columnMapping    Json     // pemetaan kolom CSV ke field sistem
  createdAt        DateTime @default(now())

  @@index([userId])
  @@map("import_batches")
}

model Gamification {
  id            String   @id @default(cuid())
  userId        String   @unique
  totalXp       Int      @default(0)
  level         Int      @default(1)
  currentStreak Int      @default(0) // streak aktif hari ini
  longestStreak Int      @default(0) // rekor streak terpanjang
  lastActiveDate DateTime? // tanggal terakhir mencatat transaksi
  updatedAt     DateTime @updatedAt

  // Relasi
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userBadges UserBadge[]
  userChallenges UserChallenge[]

  @@map("gamifications")
}

model Badge {
  id          String  @id @default(cuid())
  code        String  @unique // "STREAK_7", "TXN_50", dsb.
  name        String
  description String
  icon        String  // emoji
  xpReward    Int     @default(0)
  condition   Json    // {type: "streak", threshold: 7}

  // Relasi
  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id             String   @id @default(cuid())
  gamificationId String
  badgeId        String
  earnedAt       DateTime @default(now())

  // Relasi
  gamification Gamification @relation(fields: [gamificationId], references: [id], onDelete: Cascade)
  badge        Badge        @relation(fields: [badgeId], references: [id])

  @@unique([gamificationId, badgeId])
  @@map("user_badges")
}

model Challenge {
  id          String        @id @default(cuid())
  type        ChallengeType
  title       String
  description String
  goal        Json          // {metric: "coffee_spend", limit: 50000}
  xpReward    Int
  isActive    Boolean       @default(true)

  // Relasi
  userChallenges UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id             String   @id @default(cuid())
  gamificationId String
  challengeId    String
  progress       Float    @default(0) // 0.0 – 1.0
  isCompleted    Boolean  @default(false)
  completedAt    DateTime?
  weekStart      DateTime? // untuk tantangan mingguan
  createdAt      DateTime @default(now())

  // Relasi
  gamification Gamification @relation(fields: [gamificationId], references: [id], onDelete: Cascade)
  challenge    Challenge    @relation(fields: [challengeId], references: [id])

  @@index([gamificationId])
  @@map("user_challenges")
}